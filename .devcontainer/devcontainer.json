{
  "name": "MQL5 Gemini Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // WSLネイティブなディレクトリ構造に合わせてワークスペースを自動設定
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "mounts": [
    {
      // Windows側のMT5データフォルダをコンテナにマウント
      "source": "/mnt/c/MT5/official_ver/MetaTrader 5/MQL5",
      "target": "/mnt/mt5_mql5",
      "type": "bind"
    },
    // ↓ここからが画面出力（WSLg）に必須の設定
    {
      "source": "/tmp/.X11-unix",
      "target": "/tmp/.X11-unix",
      "type": "bind"
    //},
    //{
    //  "source": "/mnt/wslg",
    //  "target": "/mnt/wslg",
    //  "type": "bind"
    }
  ],

  "containerEnv": {
    // WSLgを利用してChromeを表示するための設定
    "DISPLAY": "${localEnv:DISPLAY}",
    // Gemini CLIの認証などでブラウザを呼び出すための設定
    "BROWSER": "/usr/bin/xdg-open",
    // 日本語環境を維持するためのロケール設定
    "LANG": "ja_JP.UTF-8",
    "LANGUAGE": "ja_JP:ja",
    "LC_ALL": "ja_JP.UTF-8",
    // Chrome系のエンジンがサンドボックスで落ちるのを防ぐ
    "ELECTRON_DISABLE_SANDBOX": "1" 
  },

  "runArgs": [
    "--cap-add=SYS_ADMIN",   // Chromeのサンドボックス機能を有効にするための権限追加
    "--shm-size=2g"             // 共有メモリを増設（Chromeのクラッシュ防止に極めて有効）
    //"--device=/dev/dri:/dev/dri" // GPU支援をコンテナに渡す（画面描画の安定化）
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "googlecloudtools.cloudcode", // Gemini連携に必要
        "ms-python.python"            // Pythonスクリプト併用時用
      ]
    }
  },

  // 起動時にデフォルトブラウザの設定を適用
  "postCreateCommand": "xdg-settings set default-web-browser google-chrome.desktop"
}